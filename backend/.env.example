# ============================================
# 知识提取模块环境配置
# ============================================

# ---------- 七牛云 AI API ----------
# 支持多个API密钥，用逗号分隔以实现真正的并发
# 注册地址: https://s.qiniu.com/aaQR32
LLM_API_KEYS_STR=key1,key2,key3,key4,key5
# 兼容旧配置（单个密钥）
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.qnaigc.com/v1

# 模型选择 (七牛云可用模型)
# 提取模型 (深度推理，适合实体/事件/时间提取)
LLM_EXTRACTION_MODEL=deepseek-r1
# 对话模型 (安全可靠，擅长情感/风格分析)
LLM_CONVERSATION_MODEL=claude-3.7-sonnet
# 快速模型 (性价比高)
LLM_FAST_MODEL=glm-4.5-air
# 备选模型 (通用高性能)
LLM_BACKUP_MODEL=deepseek-v3

# 生成参数
LLM_EXTRACTION_TEMPERATURE=0.1
LLM_CONVERSATION_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ---------- 嵌入模型配置 ----------
EMBEDDING_MODEL_NAME=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32

# ---------- 提取配置 ----------
EXTRACTION_CHUNK_SIZE=1000
EXTRACTION_CHUNK_OVERLAP=200
EXTRACTION_MAX_ENTITIES_PER_CHUNK=20
EXTRACTION_MAX_EVENTS_PER_CHUNK=10
EXTRACTION_CONFIDENCE_THRESHOLD=0.6
EXTRACTION_BATCH_SIZE=5
EXTRACTION_MAX_RETRIES=3

# ---------- 调试模式 ----------
DEBUG=false
