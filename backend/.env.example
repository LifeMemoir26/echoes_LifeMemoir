# ============================================
# Echoes LifeMemoir — 后端环境配置
# ============================================

# ！！务必修改 JWT_SECRET_KEY，LLM_API_KEYS，LLM_BASE_URL，LLM_CONCURRENCY_MULTIPLIER，GEMINI_API_KEYS，ASR_APPID，ASR_API_KEY 为真实值

# ---------- Auth / JWT ----------
# 生产环境必须是强随机长字符串；建议至少 32 位
JWT_SECRET_KEY=请替换为至少32位随机字符串
# 部署环境：development / production
ECHOES_ENV=development
# Session Cookie 配置。跨站部署如需 `none`，必须同时开启 `SESSION_COOKIE_SECURE=true`
SESSION_COOKIE_NAME=echoes_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# ---------- LLM API (OpenAI 兼容) ----------
# 多个密钥用逗号分隔可实现并发，填一个也行
LLM_API_KEYS=你的密钥1,你的密钥2,你的密钥3,你的密钥4,....,你的密钥15  
LLM_BASE_URL=你的API地址 # 例如：https://xh.v1api.cc/v1
# 并发倍率设置，请求并发数 = LLM_CONCURRENCY_MULTIPLIER * API 数量 （根据 API 提供商的要求来，并发过高会频繁触发 429 卡死程序）
LLM_CONCURRENCY_MULTIPLIER=20


# ---------- Gemini Embedding ----------
# 获取: https://aistudio.google.com/apikey
GEMINI_API_KEYS=你的密钥1,你的密钥2,你的密钥3 # 多个密钥用逗号分隔可实现并发，填一个也行
# 代理（务必科学上网，且在支持地区）
EMBEDDING_PROXY=http://127.0.0.1:7897

# ---------- 科大讯飞 RTASR 语音转写 ----------
# 在 https://console.xfyun.cn/services/rta 获取，使用标准版实时转写
ASR_APPID=你的APPID
ASR_API_KEY=你的API_KEY


# ============================================
# 可选配置项（有默认值，按需修改）
# ============================================

# 模型选择（七牛云可用模型，按模块分配）
LLM_EXTRACTION_MODEL=deepseek-v3.2      # 知识库结构化提取 + 精炼
LLM_CONVERSATION_MODEL=deepseek-v3.2   # 采访实时分析
LLM_CREATIVE_MODEL=deepseek-v3.2                   # 回忆录 + 时间轴写作（产品核心输出）
LLM_UTILITY_MODEL=deepseek-v3.2        # JSON修复、事件合并等机械任务

# 生成参数
LLM_EXTRACTION_TEMPERATURE=0.1
LLM_CONVERSATION_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=180


# ---------- Gemini Embedding ----------
# 用于向量嵌入（语义检索），不是对话模型
EMBEDDING_MODEL_NAME=models/gemini-embedding-001
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=32

# --- 知识提取参数 ---
EXTRACTION_CHUNK_SIZE=1000
EXTRACTION_CHUNK_OVERLAP=200
EXTRACTION_MAX_ENTITIES_PER_CHUNK=20
EXTRACTION_MAX_EVENTS_PER_CHUNK=10
EXTRACTION_CONFIDENCE_THRESHOLD=0.6
EXTRACTION_MAX_RETRIES=3

# --- 采访辅助参数 ---
INTERVIEW_DIALOGUE_QUEUE_SIZE=20
INTERVIEW_STORAGE_THRESHOLD=800
INTERVIEW_SUMMARY_COUNT=16
INTERVIEW_SIMILARITY_THRESHOLD=0.5
INTERVIEW_MAX_CONTEXT_SUMMARIES=50
INTERVIEW_EVENT_EXTRACTION_SIMILARITY_THRESHOLD=0.3
INTERVIEW_PENDING_EVENT_FROM_DB=16
INTERVIEW_PENDING_EVENT=32
INTERVIEW_N_REFRESH_INTERVAL=5
INTERVIEW_SUMMARY_QUEUE_SIZE=5

# --- 生成参数 ---
GENERATION_TIMELINE_LANGUAGE_SAMPLE_COUNT=10
GENERATION_MEMOIR_LANGUAGE_SAMPLE_COUNT=20

# --- 部署 (Docker) ---
# CORS 允许的前端域名，逗号分隔。生产环境留空会禁用跨域放行，只允许同源请求。
# 示例: CORS_ORIGINS=https://echoes.example.com,https://www.echoes.example.com
CORS_ORIGINS=
# 生产环境必须显式设置可信 Host，避免 Host Header 攻击
# 示例: TRUSTED_HOSTS=echoes.example.com,www.echoes.example.com
TRUSTED_HOSTS=
# 生产环境默认关闭 docs/openapi；如需临时开启可设为 true
ECHOES_ENABLE_API_DOCS=false
# 当前后端仍依赖内存态 session/material registry，生产环境默认强制单实例锁
ECHOES_ENABLE_SINGLE_INSTANCE_LOCK=true

# --- 调试 ---
DEBUG=false
