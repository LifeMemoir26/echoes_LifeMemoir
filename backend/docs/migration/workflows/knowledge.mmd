---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	ingest(ingest)
	extract(extract)
	vectorize(vectorize)
	finalize(finalize)
	__end__([<p>__end__</p>]):::last
	__start__ --> ingest;
	extract --> vectorize;
	ingest --> extract;
	vectorize --> finalize;
	finalize --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
