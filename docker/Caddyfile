{
	email {$LETSENCRYPT_EMAIL}
	admin off
}

{$APP_DOMAIN} {
	encode zstd gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

	@api path /api/v1/* /healthz
	handle @api {
		reverse_proxy backend:8000 {
			flush_interval -1
		}
	}

	handle {
		reverse_proxy frontend:3000
	}
}
